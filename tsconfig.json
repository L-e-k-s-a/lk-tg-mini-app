{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./src/*"],
			"@/app/*": ["./src/app/*"],
			"@/pages/*": ["./src/pages/*"],
			"@/widgets/*": ["./src/widgets/*"],
			"@/features/*": ["./src/features/*"],
			"@/entities/*": ["./src/entities/*"],
			"@/shared/*": ["./src/shared/*"]
		},
		"typeRoots": ["./node_modules/@types", "./src/shared/types"]
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"./src/shared/types/**/*.d.ts"
	]
}
